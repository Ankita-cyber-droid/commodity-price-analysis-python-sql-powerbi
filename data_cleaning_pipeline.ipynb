# Import psycopg2 library for PostgreSQL database connections
import psycopg2

# Import SQLAlchemy to create a database engine for PostgreSQL connection
from sqlalchemy import create_engine

# Create a connection engine to PostgreSQL database
# Format: postgresql+psycopg2://username:password@host:port/database
engine = create_engine(
    "postgresql+psycopg2://postgres:12345678()@localhost:5432/")


data.to_sql(
    name="cmo_data",
    con=engine,
    if_exists='append',
    index=False
)

