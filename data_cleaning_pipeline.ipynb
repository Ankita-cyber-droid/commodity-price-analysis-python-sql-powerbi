import pandas as pd #Import pandas library for data manipulation and analysis

# Load the Excel file into a DataFrame
data = pd.read_excel("CMO-Historical-Data-Monthly.xlsx")

# Read the Excel file structure to see available sheet names
data = pd.ExcelFile("CMO-Historical-Data-Monthly.xlsx")
data.sheet_names

# Import the specific sheet "Monthly Prices" and skip the first 4 rows
# (These rows usually contain metadata or headers not needed for analysis)
data = pd.read_excel(
    "CMO-Historical-Data-Monthly.xlsx",
    sheet_name="Monthly Prices",
    skiprows=4
)

# Display the first 5 rows of the dataset to inspect the structure
data.head()

# Remove the first row if it contains repeated headers or unnecessary values
data = data.iloc[1:]
data.head()

# Rename the unnamed column (which contains date information) to 'year_month'
data = data.rename(columns={'Unnamed: 0': 'year_month'})

# Display column names to verify the rename operation
data.columns

# Extract the year from the 'year_month' column and
# Extract the month from the 'year_month' column
data['year'] = data['year_month'].str[:4]
data['month'] = data['year_month'].str[-2:]

# Convert the 'year' and 'month' columns into a proper datetime format
data['year_month'] = pd.to_datetime(data['year'] + '-' + data['month'] + '-01')

# Reorder columns so that year and month appear first in the dataset
cols = ['year', 'month'] + [col for col in data.columns if col not in ['year','month']]
data = data[cols]

# Drop the 'year_month' column since year and month are now stored separately
data = data.drop(columns=['year_month'])

# Clean and standardize column names:
# - convert to lowercase
# - remove commas
# - remove percentage symbols
# - replace spaces with underscores
# - remove special characters
data.columns = (
    data.columns
    .str.lower()
    .str.replace(',', '')
    .str.replace('%', '')
    .str.replace(' ', '_')
    .str.replace('**', '')
)

data.head()

# Install PostgreSQL adapter for Python (used to connect Python with PostgreSQL)
